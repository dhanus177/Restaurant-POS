# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Example local:  postgresql://postgres:password@localhost:5432/pos_db
# Example Neon:   postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/pos_db?sslmode=require
# Example Supabase: postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres

DATABASE_URL="postgresql://postgres:your_password_here@localhost:5432/pos_db"

# First-run setup protection
SETUP_SECRET="change-this-setup-secret"

# One-time activation keys for sellable deployments.
# Comma-separated if you want to allow multiple keys.
LICENSE_ACTIVATION_KEYS="replace-with-your-activation-key"

# Set to true only when you intentionally want demo quick access buttons visible.
NEXT_PUBLIC_DEMO_MODE="false"

# Safety toggles for destructive or sensitive operations in production.
# Leave these as false for normal cloud deployments.
ALLOW_SEED_IN_PRODUCTION="false"
ALLOW_RESTORE_IN_PRODUCTION="false"
ALLOW_BACKUP_IN_PRODUCTION="true"
