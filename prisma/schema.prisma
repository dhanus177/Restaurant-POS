generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String    @id
  name     String
  pin      String
  role     String
  sessions Session[]
}

model Category {
  id          String     @id
  name        String
  description String?
  color       String?
  order       Int
  icon        String?
  menuItems   MenuItem[]
}

model MenuItem {
  id                 String          @id
  name               String
  price              Float
  categoryId         String
  description        String?
  image              String?
  isAvailable        Boolean         @default(true)
  applyServiceCharge Boolean         @default(false)
  category           Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  modifierGroups     ModifierGroup[]
  recipes            ProductRecipe[]
}

model ModifierGroup {
  id            String     @id
  name          String
  required      Boolean
  maxSelections Int
  menuItemId    String
  modifiers     Modifier[]
  menuItem      MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
}

model Modifier {
  id              String        @id
  name            String
  price           Float
  modifierGroupId String
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)
}

model RestaurantTable {
  id             String  @id
  number         Int
  name           String
  seats          Int
  status         String
  currentOrderId String?
}

model Order {
  id                 String      @id
  orderNumber        Int
  tableId            String?
  tableName          String?
  customerId         String?
  customerName       String?
  customerPhone      String?
  subtotal           Float
  tax                Float
  total              Float
  status             String
  paymentMethod      String?
  paymentStatus      String
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  createdBy          String
  isPriority         Boolean     @default(false)
  paymentCollectedBy String?
  customer           Customer?   @relation(fields: [customerId], references: [id])
  items              OrderItem[]
}

model Customer {
  id            String    @id @default(cuid())
  name          String
  phone         String?
  email         String?
  notes         String?
  loyaltyPoints Int       @default(0)
  lifetimeSpent Float     @default(0)
  orderCount    Int       @default(0)
  lastOrderAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  orders        Order[]
}

model OrderItem {
  id          String  @id
  orderId     String
  menuItemId  String
  name        String
  quantity    Int
  price       Float
  modifiers   Json    @default("[]")
  notes       String?
  chairNumber Int?
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Supplier {
  id             String                @id
  name           String
  contact        String
  email          String
  phone          String
  inventoryItems InventoryItem[]
  ledgerEntries  SupplierLedgerEntry[]
}

model SupplierLedgerEntry {
  id              String         @id @default(cuid())
  supplierId      String
  type            String
  reference       String?
  inventoryItemId String?
  quantity        Float?
  amount          Float
  notes           String?
  createdAt       DateTime       @default(now())
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  supplier        Supplier       @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@index([type])
}

model InventoryItem {
  id                    String                @id
  name                  String
  sku                   String                @unique
  quantity              Float
  unit                  String
  minQuantity           Float
  costPrice             Float
  supplierId            String?
  lastRestocked         DateTime?
  category              String
  supplier              Supplier?             @relation(fields: [supplierId], references: [id])
  adjustments           StockAdjustment[]
  supplierLedgerEntries SupplierLedgerEntry[]
  recipes               ProductRecipe[]       @relation("RecipeIngredient")
}

model ProductRecipe {
  id           String        @id
  productId    String        @map("product_id")
  ingredientId String        @map("ingredient_id")
  quantity     Float
  ingredient   InventoryItem @relation("RecipeIngredient", fields: [ingredientId], references: [id], onDelete: Cascade)
  product      MenuItem      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([ingredientId])
  @@map("product_recipes")
}

model StockAdjustment {
  id              String        @id
  inventoryItemId String
  type            String
  quantity        Float
  reason          String
  createdAt       DateTime      @default(now())
  createdBy       String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
}

model Settings {
  id                         String  @id @default("singleton")
  restaurantName             String
  address                    String
  phone                      String
  taxRate                    Float
  currency                   String
  currencySymbol             String
  receiptFooter              String
  logo                       String?
  requireCustomerBeforeOrder Boolean @default(false)
  kitchenPageEnabled         Boolean @default(true)
  takeawayPageEnabled        Boolean @default(true)
  whatsappBreakfastTime      String  @default("11:00")
  whatsappDinnerTime         String  @default("22:00")
  whatsappLunchTime          String  @default("16:00")
  whatsappRecipient          String?
  whatsappReportsEnabled     Boolean @default(false)
}

model WhatsAppReportDispatch {
  id         String   @id @default(cuid())
  mealType   String
  reportDate DateTime
  sentAt     DateTime @default(now())
  messageSid String?

  @@unique([mealType, reportDate])
  @@index([sentAt])
}

model CashDrawer {
  id             String              @id @default("singleton")
  openingBalance Float               @default(0)
  notes          String?
  openedAt       DateTime?
  updatedAt      DateTime            @updatedAt
  expenses       CashDrawerExpense[]
}

model CashDrawerExpense {
  id        String     @id @default(cuid())
  drawerId  String     @default("singleton")
  amount    Float
  reason    String
  createdAt DateTime   @default(now())
  createdBy String
  drawer    CashDrawer @relation(fields: [drawerId], references: [id], onDelete: Cascade)

  @@index([drawerId])
  @@index([createdAt])
}

model CashDrawerReport {
  id              String   @id @default(cuid())
  openingBalance  Float
  expectedBalance Float
  countedCash     Float
  variance        Float
  notes           String?
  closedAt        DateTime @default(now())
  closedBy        String
}

model License {
  id            String    @id @default("singleton")
  activationKey String    @unique
  status        String
  tier          String    @default("standard")
  issuedAt      DateTime  @default(now())
  activatedAt   DateTime?
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  resource   String
  resourceId String?
  details    Json?
  actorId    String?
  actorName  String?
  actorRole  String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([action])
  @@index([resource])
  @@index([actorRole])
}

model BackupSchedule {
  id             String    @id @default("singleton")
  enabled        Boolean   @default(false)
  frequencyHours Int       @default(24)
  retentionCount Int       @default(14)
  verifyChecksum Boolean   @default(true)
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  updatedAt      DateTime  @updatedAt
}

model BackupSnapshot {
  id         String   @id @default(cuid())
  trigger    String
  checksum   String
  verified   Boolean  @default(true)
  sizeBytes  Int
  exportedAt DateTime
  createdBy  String?
  payload    Json
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([trigger])
}

model Shift {
  id            String    @id @default(cuid())
  openedAt      DateTime  @default(now())
  openedBy      String
  openingFloat  Float
  status        String    @default("open")
  notes         String?
  closedAt      DateTime?
  closedBy      String?
  expectedCash  Float?
  countedCash   Float?
  variance      Float?
  denominations Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([openedAt])
  @@index([closedAt])
}
