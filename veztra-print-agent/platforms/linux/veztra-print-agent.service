[Unit]
Description=Veztra Print Agent - Background Printing Service
Documentation=https://github.com/veztra/print-agent
After=network.target

[Service]
Type=simple
User=veztra
Group=veztra
WorkingDirectory=/opt/veztra-print-agent
ExecStart=/usr/bin/node /opt/veztra-print-agent/dist/index.js
ExecReload=/bin/kill -HUP $MAINPID
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=veztra-print-agent
Environment="NODE_ENV=production"
Environment="PORT=5050"
Environment="HOST=localhost"

# Security hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
ReadWritePaths=/var/lib/veztra-print-agent
ReadWritePaths=/var/log/veztra-print-agent
ReadWritePaths=/etc/veztra-print-agent
ProtectKernelTunables=yes
ProtectControlGroups=yes
RestrictRealtime=yes
RestrictSUIDSGID=yes
LockPersonality=yes

[Install]
WantedBy=multi-user.target
