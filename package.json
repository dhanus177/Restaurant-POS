{
  "name": "restaurant-pos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:prod": "NODE_ENV=production next start -p 3000",
    "lint": "npx eslint .",
    "typecheck": "tsc --noEmit",
    "env:setup": "node scripts/setup-env.mjs",
    "env:setup:dev": "node scripts/setup-env.mjs --dev",
    "env:setup:prod": "node scripts/setup-env.mjs --prod",
    "env:setup:force": "node scripts/setup-env.mjs --force",
    "env:setup:cmd": "scripts\\setup-env.cmd",
    "license:key": "node scripts/generate-license-key.mjs",
    "release:build": "docker build -t restaurant-pos:latest .",
    "release:up": "docker compose -f deploy/docker-compose.vps.yml up -d --build",
    "release:up:ssl": "docker compose -f deploy/docker-compose.vps.ssl.yml up -d --build",
    "release:install:linux": "bash deploy/install-linux.sh ssl",
    "release:install:http:linux": "bash deploy/install-linux.sh http",
    "release:install:windows": "powershell -ExecutionPolicy Bypass -File deploy/install-windows.ps1 -Mode ssl",
    "release:install:http:windows": "powershell -ExecutionPolicy Bypass -File deploy/install-windows.ps1 -Mode http",
    "release:down": "docker compose -f deploy/docker-compose.vps.yml down",
    "release:down:ssl": "docker compose -f deploy/docker-compose.vps.ssl.yml down",
    "release:logs": "docker compose -f deploy/docker-compose.vps.yml logs -f app",
    "release:logs:ssl": "docker compose -f deploy/docker-compose.vps.ssl.yml logs -f caddy",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "node -e \"fetch('http://localhost:3000/api/seed?force=1',{method:'POST'}).then(async r=>{const t=await r.text(); console.log(t); if(!r.ok) process.exit(1)}).catch(e=>{console.error(e); process.exit(1)})\""
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-accordion": "1.2.12",
    "@radix-ui/react-alert-dialog": "1.1.15",
    "@radix-ui/react-aspect-ratio": "1.1.8",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-collapsible": "1.1.12",
    "@radix-ui/react-context-menu": "2.2.16",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-hover-card": "1.1.15",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-menubar": "1.1.16",
    "@radix-ui/react-navigation-menu": "1.2.14",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-radio-group": "1.3.8",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slider": "1.3.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-toast": "1.2.15",
    "@radix-ui/react-toggle": "1.1.10",
    "@radix-ui/react-toggle-group": "1.1.11",
    "@radix-ui/react-tooltip": "1.2.8",
    "@vercel/analytics": "1.6.1",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "4.1.0",
    "embla-carousel-react": "8.6.0",
    "input-otp": "1.4.2",
    "lucide-react": "^0.564.0",
    "next": "16.2.0",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "prisma": "^5.22.0",
    "react": "19.2.4",
    "react-day-picker": "9.13.2",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.54.1",
    "react-resizable-panels": "^2.1.7",
    "recharts": "2.15.0",
    "sonner": "^1.7.1",
    "tailwind-merge": "^3.3.1",
    "vaul": "^1.1.2",
    "zod": "^3.24.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^22",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "postcss": "^8.5",
    "tailwindcss": "^4.2.0",
    "tw-animate-css": "1.3.3",
    "typescript": "5.7.3"
  }
}
